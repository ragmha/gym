# Supabase — required for the app to connect to the backend
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase project ID — used by `bun run generate-types`
EXPO_PUBLIC_SUPABASE_PROJECT_ID=your-project-id

# (Optional) CLI-only overrides for scripts/debug-db.ts
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_PUBLISHABLE_KEY=eyJ...
