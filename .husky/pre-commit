#!/usr/bin/env sh

# Ensure hooks find bun/bunx when launched from GUI git clients (VS Code,
# GitHub Desktop, Tower, …) which often run git with a stripped PATH.
export PATH="$HOME/.bun/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

# Run lint-staged (ESLint --fix on staged files)
bunx lint-staged

# Run full typecheck (tsc needs all files, not just staged)
bun run typecheck
