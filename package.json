{
  "name": "gym",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "start": "expo start",
    "prebuild": "expo prebuild",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "bun test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "generate-types": "supabase gen types typescript --project-id \"$EXPO_PUBLIC_SUPABASE_PROJECT_ID\" --schema public > src/lib/database.types.ts",
    "db:migrate": "bun run src/scripts/migrate.ts",
    "db:migrate:create": "bun run src/scripts/create-migration.ts",
    "db:reset": "bun run src/scripts/reset-db.ts"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@legendapp/state": "^2.1.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.26",
    "@supabase/supabase-js": "^2.90.1",
    "expo": "~54.0.31",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.21",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.83.1",
    "react-native-circular-progress-indicator": "^4.4.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.19.0",
    "react-native-svg": "15.15.1",
    "react-native-tab-view": "4.2.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.0",
    "uuid": "^13.0.0",
    "victory-native": "^41.20.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.8",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "9.39.2",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^30.2.0",
    "jest-expo": "~54.0.16",
    "prettier": "^3.7.4",
    "react-test-renderer": "19.2.3",
    "supabase": "^2.72.4",
    "typescript": "5.9.3"
  },
  "private": true
}
