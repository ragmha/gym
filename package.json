{
  "name": "gym",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "start": "bunx expo start",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "native:reset": "rm -rf ios android && bun run prebuild:clean",
    "reset-project": "bun ./scripts/reset-project.js",
    "android": "bunx expo run:android",
    "ios": "bunx expo run:ios",
    "web": "bunx expo start --web",
    "test": "bunx jest",
    "test:watch": "bunx jest --watch",
    "lint": "bunx eslint .",
    "typecheck": "tsc --noEmit",
    "db:debug": "bun run scripts/debug-db.ts",
    "generate-types": "supabase gen types typescript --project-id \"$EXPO_PUBLIC_SUPABASE_PROJECT_ID\" --schema public > src/lib/database.types.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "worktree:cleanup": "bash scripts/cleanup-merged-worktrees.sh",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|react-native-tab-view|react-native-pager-view|uuid)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.33",
    "@supabase/supabase-js": "^2.95.3",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-health": "^1.19.0",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-tab-view": "4.0.5",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "uuid": "^11.0.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react-native": "^13.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^18.3.1",
    "eslint": "9.20.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "lint-staged": "^16.3.2",
    "prettier": "^3.5.1",
    "react-test-renderer": "19.1.0",
    "supabase": "^2.12.1",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": "bunx eslint --fix",
    "*.{js,jsx,mjs}": "bunx eslint --fix"
  },
  "private": true
}
