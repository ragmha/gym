{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": ".github/hooks/branch-guard/check-branch.sh",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": ".github/hooks/branch-guard/check-branch.sh",
        "cwd": ".",
        "timeoutSec": 5
      }
    ]
  }
}
